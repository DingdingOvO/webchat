[Unit]
Description=WebChat Backend Server
After=network.target mysql.service redis-server.service
Wants=mysql.service redis-server.service

[Service]
Type=simple
User={{ webchat_user }}
Group={{ webchat_group }}
WorkingDirectory={{ webchat_home }}

Environment="MYSQL_HOST=127.0.0.1"
Environment="MYSQL_PORT=3306"
Environment="MYSQL_USER=root"
Environment="MYSQL_PASSWORD={{ mysql_root_password }}"
Environment="MYSQL_DATABASE=webchat"
Environment="MONGO_HOST=127.0.0.1"
Environment="MONGO_PORT=27017"
Environment="REDIS_HOST=127.0.0.1"
Environment="REDIS_PORT=6379"
Environment="JWT_SECRET={{ jwt_secret }}"
Environment="JAVA_OPTS=-Xms{{ java_xms }} -Xmx{{ java_xmx }} -XX:+UseG1GC"

ExecStart=/usr/bin/java $JAVA_OPTS -jar {{ webchat_home }}/app.jar
ExecStop=/bin/kill -SIGTERM $MAINPID
Restart=on-failure
RestartSec=10
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
